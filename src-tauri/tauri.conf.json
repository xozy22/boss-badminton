{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BOSS",
  "version": "2.7.2",
  "identifier": "com.badminton.turnierplaner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "BOSS - Badminton Operating and Scheduling System",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost asset: https://asset.localhost https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBMTA0OTY1OTdDODVGNDIKUldSQ1g4aVhaVWtRU2s4SUxtaDVUc3lnbjd4cHhHTFBubWNoclVjbEZOa1BpVWdYTERRZjhaaS8K",
      "endpoints": [
        "https://github.com/xozy22/boss-badminton/releases/latest/download/latest.json"
      ]
    }
  }
}
