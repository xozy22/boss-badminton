{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Turnierplaner",
  "version": "0.5.0",
  "identifier": "com.badminton.turnierplaner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Badminton Turnierplaner",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com ipc: http://ipc.localhost asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRBMTA0OTY1OTdDODVGNDIKUldSQ1g4aVhaVWtRU2s4SUxtaDVUc3lnbjd4cHhHTFBubWNoclVjbEZOa1BpVWdYTERRZjhaaS8K",
      "endpoints": [
        "https://github.com/xozy22/badminton-turnierplaner/releases/latest/download/latest.json"
      ]
    }
  }
}
